# Google AI Studio API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Optional: pin a model. If unset, the backend resolves the best available
# model at startup from this preference order:
#   gemini-3.5-flash > gemini-3.1-flash-lite > gemini-3-flash-preview > gemini-2.5-flash
# GEMINI_MODEL=gemini-3.5-flash

# Fast, high-quota model for the one-request exception-triage path.
# GEMINI_TRIAGE_MODEL=gemini-3.1-flash-lite

# Optional: stronger model used for billing document extraction (vision).
# Falls back to the resolved default when unset.
# GEMINI_VISION_MODEL=gemini-3.1-pro-preview

# Where the frontend runs (CORS allowlist)
FRONTEND_ORIGIN=http://localhost:3000
